<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FairFeed — Project Presentation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#08090F; --bg1:rgba(255,255,255,0.03); --bg2:rgba(255,255,255,0.055);
  --text:#F0EEF8; --text2:rgba(240,238,248,0.6); --text3:rgba(240,238,248,0.35);
  --accent:#7B73E0; --accent2:#2A8BE0; --gold:#F5A623; --green:#1BAD87; --red:#E05A2F;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.13);
  --card-bg:rgba(255,255,255,0.03); --card-hover:rgba(255,255,255,0.055);
  --hdr-h:64px; --ftr-h:60px;
  --font:'Inter',system-ui,sans-serif; --font-head:'Space Grotesk','Inter',system-ui,sans-serif;
}

html,body{height:100%;overflow:hidden}
body{font-family:var(--font);background:var(--bg);color:var(--text);display:flex;flex-direction:column}

/* ── Ambient background ── */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 700px 500px at 10% 0%,rgba(83,74,183,0.07) 0%,transparent 60%),
    radial-gradient(ellipse 600px 400px at 90% 100%,rgba(24,95,165,0.06) 0%,transparent 60%),
    radial-gradient(ellipse 400px 300px at 50% 50%,rgba(240,238,248,0.01) 0%,transparent 70%);
  z-index:0;
}

/* ══════════════ HEADER ══════════════ */
.hdr{
  position:relative;z-index:20;flex-shrink:0;height:var(--hdr-h);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 40px;
  background:rgba(8,9,15,0.85);backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
}
.hdr-brand{display:flex;align-items:center;gap:10px}
.hdr-orb{width:9px;height:9px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));box-shadow:0 0 12px rgba(123,115,224,0.7)}
.hdr-name{font-family:var(--font-head);font-size:17px;font-weight:800;letter-spacing:-.4px}
.hdr-name em{font-style:normal;color:var(--accent)}
.hdr-tag{font-size:10px;color:var(--text3);font-weight:500;letter-spacing:.07em;text-transform:uppercase;padding:3px 9px;border:1px solid var(--border2);border-radius:20px}
.hdr-center{display:flex;flex-direction:column;align-items:center;gap:6px}
.progress-rail{width:220px;height:2px;background:rgba(255,255,255,0.08);border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2),var(--gold));border-radius:2px;transition:width .4s ease;width:0%}
.slide-counter{font-size:11px;color:var(--text3);font-weight:600;letter-spacing:.1em}
.hdr-right{display:flex;align-items:center;gap:12px}
.dots{display:flex;gap:5px;align-items:center}
.d{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.18);cursor:pointer;border:none;transition:all .22s;flex-shrink:0}
.d.on{background:var(--accent);box-shadow:0 0 8px rgba(123,115,224,0.7);width:18px;border-radius:3px}

/* ══════════════ MAIN STAGE ══════════════ */
.stage{
  position:relative;z-index:1;flex:1;overflow:hidden;
}
.sl{
  position:absolute;inset:0;overflow-y:auto;
  opacity:0;transform:translateX(32px);
  transition:opacity .38s ease,transform .38s ease;
  pointer-events:none;
  scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.08) transparent;
}
.sl::-webkit-scrollbar{width:4px}
.sl::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.08);border-radius:2px}
.sl.on{opacity:1;transform:none;pointer-events:auto}
.sl.out{opacity:0;transform:translateX(-32px)}
.inner{max-width:1080px;margin:0 auto;padding:52px 56px 48px}

/* ══════════════ FOOTER ══════════════ */
.ftr{
  position:relative;z-index:20;flex-shrink:0;height:var(--ftr-h);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 40px;
  background:rgba(8,9,15,0.85);backdrop-filter:blur(24px);
  border-top:1px solid var(--border);
}
.slide-label{font-size:12px;color:var(--text3);font-weight:500;letter-spacing:.06em;text-transform:uppercase;min-width:160px}
.nav-btn{
  display:flex;align-items:center;gap:7px;
  padding:8px 22px;border-radius:9px;
  border:1px solid var(--border2);background:rgba(255,255,255,0.04);
  color:var(--text2);font-family:var(--font);font-size:13px;font-weight:500;
  cursor:pointer;transition:all .18s;
}
.nav-btn:hover:not(:disabled){background:rgba(255,255,255,0.08);color:var(--text);border-color:rgba(255,255,255,0.2)}
.nav-btn:disabled{opacity:.28;cursor:default}
.nav-btn.next{background:rgba(123,115,224,0.15);border-color:rgba(123,115,224,0.35);color:rgba(180,175,240,0.9)}
.nav-btn.next:hover:not(:disabled){background:rgba(123,115,224,0.28);color:#fff}

/* ══════════════ TYPOGRAPHY ══════════════ */
.eyebrow{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:14px}
.eyebrow-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px rgba(123,115,224,0.8);flex-shrink:0}
.h1{font-family:var(--font-head);font-size:clamp(34px,4.5vw,56px);font-weight:800;line-height:1.08;letter-spacing:-1.5px;color:#fff;margin-bottom:18px}
.h1 span{background:linear-gradient(90deg,var(--accent),var(--accent2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.h2{font-family:var(--font-head);font-size:clamp(22px,3vw,36px);font-weight:800;line-height:1.15;letter-spacing:-.8px;color:#fff;margin-bottom:16px}
.h2 span{background:linear-gradient(90deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.lead{font-size:15px;line-height:1.85;color:var(--text2);margin-bottom:32px;max-width:600px}
.body-p{font-size:14px;line-height:1.8;color:var(--text2);margin-bottom:20px}
.section-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:10px;margin-top:28px}

/* ══════════════ CARDS GRID ══════════════ */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin:20px 0}
.card{
  background:var(--card-bg);border:1px solid var(--border);
  border-radius:16px;padding:22px;cursor:pointer;transition:all .22s;
}
.card:hover{background:var(--card-hover);border-color:var(--border2);transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,0.25)}
.card.open{border-color:rgba(123,115,224,0.45);background:rgba(123,115,224,0.08)}
.card-icon{font-size:22px;margin-bottom:10px}
.card-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:5px}
.card-sub{font-size:12px;color:var(--text2);line-height:1.55}
.card-detail{margin-top:12px;padding-top:12px;border-top:1px solid rgba(123,115,224,0.25);font-size:12px;color:rgba(180,175,240,0.85);line-height:1.7;display:none}
.card.open .card-detail{display:block}

/* ══════════════ OVERVIEW GRID ══════════════ */
.ov-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:24px 0}
.ov-card{
  background:var(--card-bg);border:1px solid var(--border);
  border-radius:16px;padding:24px;cursor:pointer;transition:all .22s;
}
.ov-card:hover{background:var(--card-hover);border-color:var(--border2);transform:translateY(-3px);box-shadow:0 12px 36px rgba(0,0,0,0.3)}
.ov-icon{font-size:26px;margin-bottom:12px}
.ov-num{font-size:10px;font-weight:700;color:var(--text3);letter-spacing:.1em;margin-bottom:4px}
.ov-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:6px}
.ov-sub{font-size:12px;color:var(--text2);line-height:1.6}

/* ══════════════ PIPELINE VIZ ══════════════ */
.pipeline{display:flex;align-items:center;padding:28px 0 20px;overflow-x:auto;gap:0}
.pnode{flex-shrink:0;text-align:center;cursor:pointer;padding:0 8px;transition:transform .2s}
.pnode:hover{transform:translateY(-3px)}
.pcirc{
  width:56px;height:56px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 8px;font-size:22px;
  border:1.5px solid rgba(255,255,255,0.15);
  background:var(--card-bg);
  box-shadow:0 4px 16px rgba(0,0,0,0.3);
  transition:all .2s;
}
.pnode:hover .pcirc{border-color:var(--accent);box-shadow:0 4px 24px rgba(123,115,224,0.35)}
.plabel{font-size:10px;color:var(--text2);font-weight:600;line-height:1.3}
.pconn{flex-shrink:0;display:flex;align-items:center;padding:0 2px}
.pconn-line{width:20px;height:1px;background:rgba(255,255,255,0.12)}
.pconn-tip{width:0;height:0;border-top:4px solid transparent;border-bottom:4px solid transparent;border-left:6px solid rgba(255,255,255,0.12)}

/* ══════════════ CHAIN ══════════════ */
.chain{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin:16px 0}
.cnode{font-size:11px;font-weight:500;padding:6px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card-bg);color:var(--text2)}
.cnode.hl{border-color:rgba(123,115,224,0.45);background:rgba(123,115,224,0.12);color:rgba(180,175,240,0.95);font-weight:600}
.carrow{color:var(--text3);font-size:13px}

/* ══════════════ INFO BOX ══════════════ */
.infobox{
  background:rgba(123,115,224,0.07);
  border:1px solid rgba(123,115,224,0.2);
  border-left:3px solid var(--accent);
  border-radius:12px;padding:14px 18px;
  margin:16px 0;font-size:13px;color:var(--text2);line-height:1.7;
}
.infobox strong{color:var(--text)}
.infobox.green{background:rgba(27,173,135,0.07);border-color:rgba(27,173,135,0.2);border-left-color:var(--green)}
.infobox.gold{background:rgba(245,166,35,0.07);border-color:rgba(245,166,35,0.2);border-left-color:var(--gold)}

/* ══════════════ SOURCES GRID ══════════════ */
.src-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:7px;margin:16px 0}
.src-tag{
  font-size:11px;font-weight:500;padding:7px 6px;
  border-radius:9px;border:1px solid var(--border);
  color:var(--text2);background:var(--card-bg);
  text-align:center;cursor:pointer;transition:all .15s;line-height:1.3;
}
.src-tag:hover,.src-tag.lit{border-color:rgba(123,115,224,0.45);color:rgba(180,175,240,0.9);background:rgba(123,115,224,0.1)}
.src-type{font-size:9px;color:var(--text3);margin-top:3px}

/* ══════════════ PARAMS GRID ══════════════ */
.pg{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:8px;margin:16px 0}
.ppill{
  background:var(--card-bg);border:1px solid var(--border);
  border-radius:10px;padding:11px 13px;cursor:pointer;transition:all .18s;
}
.ppill:hover{border-color:var(--border2);background:var(--card-hover)}
.ppill.open{border-color:rgba(123,115,224,0.45);background:rgba(123,115,224,0.08)}
.pp-num{font-size:9px;font-weight:800;margin-bottom:3px;letter-spacing:.04em}
.pp-name{font-size:12px;font-weight:700;color:#fff;margin:2px 0}
.pp-group{font-size:10px;color:var(--text3)}
.pp-detail{font-size:11px;color:rgba(180,175,240,0.85);line-height:1.6;margin-top:8px;display:none}
.ppill.open .pp-detail{display:block}

/* ══════════════ SHAP / SCORE BARS ══════════════ */
.bar-row{display:flex;align-items:center;gap:12px;margin:7px 0}
.bar-label{font-size:12px;color:var(--text2);min-width:150px}
.bar-track{flex:1;height:10px;background:rgba(255,255,255,0.07);border-radius:5px;overflow:hidden}
.bar-fill{height:100%;border-radius:5px;transition:width .6s ease}
.bar-val{font-size:11px;color:var(--text3);min-width:38px;text-align:right}

/* ══════════════ SCHEMA TABLE ══════════════ */
.schema-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin:16px 0}
.coll{background:var(--card-bg);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.coll-head{padding:10px 14px;font-size:11px;font-weight:700;color:var(--accent);background:rgba(123,115,224,0.08);border-bottom:1px solid var(--border)}
.coll-row{padding:6px 14px;font-size:11px;color:var(--text2);border-bottom:1px solid var(--border);display:flex;justify-content:space-between}
.coll-row:last-child{border-bottom:none}
.coll-type{color:var(--text3);font-style:italic}

/* ══════════════ FLOW DIAGRAM ══════════════ */
.flow-block{margin:18px 0}
.flow-lbl{font-size:11px;font-weight:600;color:var(--text3);margin-bottom:10px;letter-spacing:.04em}
.flow-row{display:flex;align-items:stretch;gap:8px;flex-wrap:wrap}
.fbox{flex:1;min-width:135px;border-radius:10px;padding:12px 14px;border:1px solid}
.fbox.ui{border-color:rgba(123,115,224,0.4);background:rgba(123,115,224,0.08)}
.fbox.api{border-color:rgba(27,173,135,0.4);background:rgba(27,173,135,0.07)}
.fbox.db{border-color:rgba(42,139,224,0.4);background:rgba(42,139,224,0.07)}
.fbox.alg{border-color:rgba(245,166,35,0.4);background:rgba(245,166,35,0.07)}
.flyr{font-size:9px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;margin-bottom:5px}
.fbox.ui .flyr{color:rgba(180,175,240,0.9)}
.fbox.api .flyr{color:rgba(74,200,165,0.9)}
.fbox.db .flyr{color:rgba(100,180,240,0.9)}
.fbox.alg .flyr{color:rgba(245,190,80,0.9)}
.fcont{font-size:11px;color:var(--text2);line-height:1.6}
.farr{display:flex;align-items:center;color:var(--text3);font-size:16px;padding:0 2px;align-self:center;flex-shrink:0}
.m{display:inline-block;font-size:8px;font-weight:800;padding:1px 5px;border-radius:3px;margin-right:3px}
.mget{background:rgba(27,173,135,0.2);color:#4BC8A0}
.mpost{background:rgba(245,166,35,0.2);color:#F5B84A}

/* ══════════════ COMPARISON TABLE ══════════════ */
.ctable{width:100%;border-collapse:collapse;font-size:12px;margin:16px 0}
.ctable th{text-align:left;padding:9px 12px;background:rgba(255,255,255,0.04);border:1px solid var(--border);color:var(--text3);font-weight:700;font-size:10px;letter-spacing:.05em;text-transform:uppercase}
.ctable td{padding:9px 12px;border:1px solid var(--border);color:var(--text2);vertical-align:top;line-height:1.55}
.ctable tr:hover td{background:rgba(255,255,255,0.02)}
.tag{display:inline-block;font-size:9px;font-weight:800;padding:2px 7px;border-radius:4px}
.trss{background:rgba(27,173,135,0.2);color:#4BC8A0}
.trest{background:rgba(245,166,35,0.2);color:#F5B84A}
.tspec{background:rgba(123,115,224,0.2);color:rgba(180,175,240,0.9)}

/* ══════════════ CODE BLOCK ══════════════ */
.codebox{background:rgba(0,0,0,0.55);border:1px solid rgba(255,255,255,0.09);border-radius:12px;margin:16px 0;display:flex;flex-direction:column}
.codebox-head{padding:9px 16px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(240,238,248,0.45);border-bottom:1px solid rgba(255,255,255,0.07);background:rgba(255,255,255,0.03);border-radius:12px 12px 0 0;flex-shrink:0}
.code{display:block;padding:18px 20px;font-family:'Courier New',Consolas,monospace;font-size:12.5px;line-height:1.9;color:rgba(255,255,255,0.72);white-space:pre-wrap;word-break:break-word;border-radius:0 0 12px 12px;overflow-x:auto}
.kw{color:#b39dfa;font-weight:700}
.str{color:#7ec98b}
.num{color:#f5c264}
.cmt{color:rgba(255,255,255,0.28);font-style:italic}

/* ══════════════ STEPS ══════════════ */
.steps{margin:16px 0;position:relative}
.steps::before{content:'';position:absolute;left:20px;top:24px;bottom:24px;width:1.5px;background:linear-gradient(to bottom,rgba(123,115,224,0.35),rgba(42,139,224,0.15));z-index:0}
.step{display:flex;gap:16px;align-items:flex-start;padding:8px 0;position:relative;z-index:1}
.step-n{flex-shrink:0;width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:800;box-shadow:0 0 18px rgba(123,115,224,0.35)}
.step-body{flex:1;background:var(--card-bg);border:1px solid var(--border);border-radius:10px;padding:13px 16px}
.step-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:5px}
.step-desc{font-size:12px;color:var(--text2);line-height:1.65}

/* ══════════════ VARIANCE BARS ══════════════ */
.var-row{display:flex;align-items:center;gap:12px;margin:7px 0;cursor:pointer;padding:7px 10px;border-radius:9px;transition:background .15s}
.var-row:hover{background:rgba(255,255,255,0.04)}
.var-name{font-size:12px;color:var(--text2);min-width:145px}
.var-track{flex:1;height:8px;background:rgba(255,255,255,0.07);border-radius:4px;overflow:hidden}
.var-fill{height:100%;border-radius:4px;transition:width .6s ease}
.var-num{font-size:10px;color:var(--text3);min-width:55px;text-align:right}
.var-flag{font-size:9px;font-weight:800;padding:2px 8px;border-radius:4px;white-space:nowrap}

/* ══════════════ BADGE ROW ══════════════ */
.badge-row{display:flex;align-items:flex-start;gap:12px;padding:14px 0;border-top:1px solid var(--border);margin-top:16px;flex-wrap:wrap}
.badge-label{font-size:10px;font-weight:700;color:var(--accent);min-width:70px;padding-top:4px}
.badges{display:flex;gap:6px;flex-wrap:wrap}
.badge{font-size:10px;padding:3px 9px;border-radius:5px;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--text2)}

/* ══════════════ ANIMATIONS ══════════════ */
@keyframes fadeup{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
.sl.on .h1,.sl.on .h2{animation:fadeup .4s ease both}
.sl.on .lead,.sl.on .body-p{animation:fadeup .4s ease .08s both}

/* ══════════════ TWO-COL ══════════════ */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:16px 0}
@media(max-width:760px){.two-col,.ov-grid,.flow-row{grid-template-columns:1fr}.inner{padding:32px 20px}}
</style>
</head>
<body>

<!-- ═══════ HEADER ═══════ -->
<header class="hdr">
  <div class="hdr-brand">
    <div class="hdr-orb"></div>
    <div class="hdr-name"><em>Fair</em>Feed</div>
    <div class="hdr-tag">Neural Bias Pipeline</div>
  </div>
  <div class="hdr-center">
    <div class="progress-rail"><div class="progress-fill" id="pf"></div></div>
    <div class="slide-counter" id="ctr">01 / 10</div>
  </div>
  <div class="hdr-right">
    <div class="dots" id="dots"></div>
  </div>
</header>

<!-- ═══════ STAGE ═══════ -->
<main class="stage">

<!-- ── Slide 0: Overview ── -->
<div class="sl on" id="s0">
<div class="inner">
  <div class="eyebrow"><div class="eyebrow-dot"></div>Overview</div>
  <div class="h1">FairFeed —<br><span>Neural Bias Pipeline</span></div>
  <p class="lead">An end-to-end AI platform that ingests 28 global news sources, clusters stories, scores every article across 17 bias parameters, and surfaces exactly <em style="color:var(--accent);font-style:normal">where</em> journalism diverges — with full explainability.</p>

  <div class="pipeline" id="pipeline"></div>

  <div class="ov-grid">
