</main>

<!-- ═══════ FOOTER ═══════ -->
<footer class="ftr">
  <button class="nav-btn" id="prevBtn" onclick="go(cur-1)">← Prev</button>
  <div class="slide-label" id="slLabel">Overview</div>
  <button class="nav-btn next" id="nextBtn" onclick="go(cur+1)">Next →</button>
</footer>

<script>
const SLIDES=['Overview','Feed Ingest','Story Clustering','BERT Encoding','17 Parameters','MongoDB','HTTP Map','API Interaction','Data Extraction','Comparison Engine','Frontend Architecture','Backend Architecture','Gamification','Pipeline Enhancements'];
let cur=0;

function go(n){
  if(n<0||n>=SLIDES.length)return;
  const prev=document.getElementById('s'+cur);
  const next=document.getElementById('s'+n);
  if(prev!==next){prev.classList.remove('on');prev.classList.add('out');setTimeout(()=>prev.classList.remove('out'),420);}
  next.classList.add('on');
  cur=n;
  upd();
  if(n===4&&!document.getElementById('pg').children.length){buildParams();buildShap();buildScores();}
  if(n===9&&!document.getElementById('varbars').children.length){buildVarBars();}
}

function upd(){
  const t=SLIDES.length;
  document.getElementById('pf').style.width=(cur/(t-1)*100)+'%';
  document.getElementById('ctr').textContent=String(cur+1).padStart(2,'0')+' / '+String(t).padStart(2,'0');
  document.getElementById('slLabel').textContent=SLIDES[cur];
  document.querySelectorAll('.d').forEach((d,i)=>d.classList.toggle('on',i===cur));
  document.getElementById('prevBtn').disabled=cur===0;
  document.getElementById('nextBtn').disabled=cur===t-1;
}

// Build nav dots
(function(){
  const dd=document.getElementById('dots');
  SLIDES.forEach((s,i)=>{
    const d=document.createElement('button');
    d.className='d'+(i===0?' on':'');
    d.title=s;d.onclick=()=>go(i);
    dd.appendChild(d);
  });
})();

// Pipeline
(function(){
  const nodes=[
    {icon:'🌐',label:'22 APIs',slide:1},{icon:'🔗',label:'Cluster',slide:2},
    {icon:'🧠',label:'BERT+PE',slide:3},{icon:'📊',label:'17 Params',slide:4},
    {icon:'🔍',label:'SHAP',slide:4},{icon:'🗄️',label:'MongoDB',slide:5},
    {icon:'🖥️',label:'UI Score',slide:6},
  ];
  const p=document.getElementById('pipeline');
  nodes.forEach((n,i)=>{
    const nd=document.createElement('div');nd.className='pnode';
    nd.innerHTML=`<div class="pcirc">${n.icon}</div><div class="plabel">${n.label}</div>`;
    nd.onclick=()=>go(n.slide);p.appendChild(nd);
    if(i<nodes.length-1){const c=document.createElement('div');c.className='pconn';c.innerHTML='<div class="pconn-line"></div><div class="pconn-tip"></div>';p.appendChild(c);}
  });
})();

// Sources
(function(){
  const srcs=[
    ['BBC','RSS'],['Reuters','REST'],['Al Jazeera','RSS'],['AP News','REST'],
    ['NPR','RSS'],['The Hindu','RSS'],['TOI','RSS'],['Der Spiegel','RSS'],
    ['NHK Japan','RSS'],['AllAfrica','RSS'],['Mercopress','RSS'],['NewsData.io','API'],
    ['NewsAPI','API'],['GDELT','API'],['Guardian','RSS'],['DW','RSS'],
    ['France 24','RSS'],['RT','RSS'],['CBC','RSS'],['Al Monitor','RSS'],
    ['Dawn','RSS'],['El País','RSS'],['Euronews','RSS'],['ABC AU','RSS'],
  ];
  const g=document.getElementById('srcs');
  srcs.forEach(([name,type])=>{
    const el=document.createElement('div');el.className='src-tag';
    el.innerHTML=`${name}<div class="src-type">${type}</div>`;
    el.onclick=()=>el.classList.toggle('lit');
    g.appendChild(el);
  });
})();

// 17 Params
const PARAMS=[
  {n:'01',name:'Political Lean',g:'Political',gc:'#7B73E0',d:'Left keywords: "wealth tax","social justice". Right: "free market","deregulation". Score = |right−left| / total × 100.'},
  {n:'02',name:'Confirmation Bias',g:'Political',gc:'#7B73E0',d:'Phrases: "as expected","no surprise","proves once again". +20 per hit, capped at 80. Detects narrative reinforcement.'},
  {n:'03',name:'Emotional Tone',g:'Language',gc:'#F5A623',d:'TextBlob subjectivity × 100 + charged word count (shocking, catastrophic, heroic). High = emotional not factual register.'},
  {n:'04',name:'Sensationalism',g:'Language',gc:'#F5A623',d:'Clickbait lexicon: breaking, explosive, bombshell, stunning. Headline hit gets 2× multiplier. ALL-CAPS title adds +15.'},
  {n:'05',name:'Loaded Language',g:'Language',gc:'#F5A623',d:'Manipulative terms: radical, regime, fake news, deep state. +10 per hit, max 100. Direction-neutral — catches both political sides.'},
  {n:'06',name:'Word Choice Variance',g:'Language',gc:'#F5A623',d:'TF-IDF frequency of charged vocab vs neutral synonyms. High = selective word choice revealing stance even when individual words seem mild.'},
  {n:'07',name:'Headline Bias',g:'Structural',gc:'#1BAD87',d:'Sensational word count + (1 − cosine_sim(headline, body)) × 50. Low headline-body overlap = clickbait mismatch.'},
  {n:'08',name:'Framing Bias',g:'Structural',gc:'#1BAD87',d:'Negative frame: crisis, collapse, danger. Positive: opportunity, progress, triumph. Score = |neg−pos| / total × 100.'},
  {n:'09',name:'Omission Bias',g:'Structural',gc:'#1BAD87',d:'Checklist: citations present? Expert quotes? Counter-view? Multiple perspectives? Each missing = +25. Detects what is NOT said.'},
  {n:'10',name:'Attribution Bias',g:'Structural',gc:'#1BAD87',d:'Officials only → +40. Critics only → +40. Balanced (both) → 0. No attribution → +30. One-sided sourcing detection.'},
  {n:'11',name:'False Balance',g:'Contextual',gc:'#E05A2F',d:'Phrases: "some scientists disagree","experts divided". Detects giving fringe views equal rhetorical weight as scientific consensus.'},
  {n:'12',name:'Agenda Setting',g:'Contextual',gc:'#E05A2F',d:'Action-push language: "must act now","threat to democracy","wake up call". +15 per hit, max 90. Manufactured urgency.'},
  {n:'13',name:'Geographic Bias',g:'Contextual',gc:'#E05A2F',d:'NER GPE entity counts. Score = dominant_location / total × 100. High = regional obsession, no global context.'},
  {n:'14',name:'Temporal Bias',g:'Contextual',gc:'#E05A2F',d:'Historical references vs present/future tense ratio. High historical ratio = over-reliance on framing through past analogies.'},
  {n:'15',name:'Source Credibility',g:'Source',gc:'#2A8BE0',d:'Domain reputation dict: reuters.com→10, bbc.com→15, breitbart.com→72, unknown→50. Applied as Bayesian prior before reading text.'},
  {n:'16',name:'Coverage Intensity',g:'Source',gc:'#2A8BE0',d:'max_term_freq / mean_term_freq. High = one topic mentioned far more than others. Obsessive repetition = bias signal.'},
  {n:'17',name:'Fact vs Opinion',g:'Source',gc:'#2A8BE0',d:'Fact markers: "according to data","study shows". Opinion: "clearly","obviously","everyone knows". Ratio maps to 0–100.'},
];

function buildParams(){
  const g=document.getElementById('pg');
  PARAMS.forEach(p=>{
    const el=document.createElement('div');el.className='ppill';
    el.innerHTML=`<div class="pp-num" style="color:${p.gc}">#${p.n}</div><div class="pp-name">${p.name}</div><div class="pp-group" style="color:${p.gc}">${p.g}</div><div class="pp-detail">${p.d}</div>`;
    el.onclick=()=>{document.querySelectorAll('.ppill').forEach(x=>{if(x!==el)x.classList.remove('open');});el.classList.toggle('open');};
    g.appendChild(el);
  });
}

function buildShap(){
  const sb=document.getElementById('shap');
  const data=[
    {name:'Framing Bias',val:82,c:'#E05A2F'},{name:'Omission Bias',val:74,c:'#1BAD87'},
    {name:'Sensationalism',val:68,c:'#F5A623'},{name:'Loaded Language',val:61,c:'#7B73E0'},
    {name:'Attribution Bias',val:45,c:'#2A8BE0'},{name:'Emotional Tone',val:38,c:'#F5A623'},
    {name:'Political Lean',val:22,c:'#7B73E0'},
  ];
  data.forEach(d=>{
    const r=document.createElement('div');r.className='bar-row';
    r.innerHTML=`<div class="bar-label">${d.name}</div><div class="bar-track"><div class="bar-fill" style="width:0%;background:${d.c}"></div></div><div class="bar-val">${(d.val/100).toFixed(2)}</div>`;
    sb.appendChild(r);
    setTimeout(()=>r.querySelector('.bar-fill').style.width=d.val+'%',200);
  });
}

function buildScores(){
  const sr=document.getElementById('scores');
  const data=[
    {name:'Overall Score',val:58,c:'#E05A2F',label:'High Bias'},
    {name:'Framing Bias',val:82,c:'#E05A2F',label:'82/100'},
    {name:'Omission Bias',val:74,c:'#1BAD87',label:'74/100'},
    {name:'Political Lean',val:22,c:'#7B73E0',label:'22/100'},
    {name:'Source Credibility',val:15,c:'#2A8BE0',label:'15/100'},
  ];
  data.forEach(d=>{
    const r=document.createElement('div');r.className='bar-row';
    r.innerHTML=`<div class="bar-label">${d.name}</div><div class="bar-track"><div class="bar-fill" style="width:${d.val}%;background:${d.c}"></div></div><div class="bar-val" style="color:${d.c};font-weight:600">${d.label}</div>`;
    sr.appendChild(r);
  });
}

function buildVarBars(){
  const c=document.getElementById('varbars');
  const data=[
    {name:'Framing Bias',variance:842,pct:94,flag:'MOST DIVERGENT',fc:'#E05A2F',flagC:'rgba(224,90,47,0.15)',info:'<strong>Framing Bias — variance 842 (highest).</strong> BBC frames: "recovery opportunity". Fox: "government-caused crisis". Al Jazeera: global South impact. Reuters: neutral financial language. Same facts, four completely different frames.'},
    {name:'Omission Bias',variance:720,pct:80,flag:'HIGH',fc:'#1BAD87',flagC:'rgba(27,173,135,0.15)',info:'<strong>Omission Bias — variance 720.</strong> Reuters cited 3 expert sources + counter-view paragraph. Fox had zero expert citations and no opposing view. Structural omission gap between outlets.'},
    {name:'Sensationalism',variance:610,pct:68,flag:'HIGH',fc:'#F5A623',flagC:'rgba(245,166,35,0.15)',info:'<strong>Sensationalism — variance 610.</strong> Fox: "EXPLOSIVE: Economy in FREEFALL". BBC: "UK economy contracts 0.2%". Same number, purely different editorial word choice around it.'},
    {name:'Loaded Language',variance:490,pct:55,flag:'MODERATE',fc:'#7B73E0',flagC:'rgba(123,115,224,0.15)',info:'<strong>Loaded Language — variance 490.</strong> Breitbart: "radical government overreach". NPR: "policy expansion". Same policy, vastly different vocabulary — loaded language gap exposed.'},
    {name:'Attribution Bias',variance:310,pct:35,flag:'MODERATE',fc:'#2A8BE0',flagC:'rgba(42,139,224,0.15)',info:'<strong>Attribution Bias — variance 310.</strong> Reuters quoted officials + economists + critics. One outlet quoted only government officials. Attribution variance shows who gets a voice — and who does not.'},
    {name:'Political Lean',variance:180,pct:20,flag:'LOW',fc:'#7B73E0',flagC:'rgba(90,90,84,0.15)',info:'<strong>Political Lean — variance 180 (low).</strong> These outlets do not differ greatly on explicit left/right keyword counts. The bias is primarily structural (framing, omission) — not overt political language.'},
    {name:'Source Credibility',variance:90,pct:10,flag:'LOW',fc:'#2A8BE0',flagC:'rgba(90,90,84,0.15)',info:'<strong>Source Credibility — variance 90 (lowest).</strong> BBC, Reuters, Al Jazeera, NPR all have similar credibility scores — NOT the differentiating factor in this story.'},
  ];
  data.forEach(d=>{
    const row=document.createElement('div');row.className='var-row';
    row.innerHTML=`<div class="var-name">${d.name}</div><div class="var-track"><div class="var-fill" style="width:${d.pct}%;background:${d.fc}"></div></div><div class="var-num">σ²=${d.variance}</div><span class="var-flag" style="color:${d.fc};background:${d.flagC}">${d.flag}</span>`;
    row.onclick=()=>{document.getElementById('varinfo').innerHTML=d.info;};
    c.appendChild(row);
  });
}

// keyboard nav
document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key==='ArrowDown')go(cur+1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp')go(cur-1);
});

upd();
</script>
</body>
</html>
